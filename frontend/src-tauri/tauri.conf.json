{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Code Desktop",
  "version": "0.1.0",
  "identifier": "com.claude-code.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run build:sidecar && (lsof -ti:1420 >/dev/null 2>&1 || npm run dev)",
    "beforeBuildCommand": ""
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Claude Code Desktop",
        "width": 1220,
        "height": 798,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/claude-sidecar"
    ],
    "resources": {
      "../dist": "dist/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false,
        "installerHooks": "nsis/uninstall-hooks.nsh"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
